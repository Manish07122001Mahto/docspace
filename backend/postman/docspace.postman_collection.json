    {
      "name": "Documents",
      "item": [
        {
          "name": "Get User Workspace",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{host}}/documents?user_id={{user_id}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "documents"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{user_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Project Overview\",\n  \"owner_id\": \"{{user_id}}\",\n  \"content_html\": \"<h1>Project Overview</h1><p>This is a new document created via API.</p>\"\n}"
            },
            "url": {
              "raw": "{{host}}/documents",
              "host": [
                "{{host}}"
              ],
              "path": [
                "documents"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Single Document",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{host}}/documents/{{document_id}}?user_id={{user_id}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "documents",
                "{{document_id}}"
              ],
              "query": [
                {
                  "key": "user_id",
                  "value": "{{user_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Document",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Overview\",\n  \"content_html\": \"<h1>Updated Project Overview</h1><p>This content has been modified.</p>\"\n}"
            },
            "url": {
              "raw": "{{host}}/documents/{{document_id}}",
              "host": [
                "{{host}}"
              ],
              "path": [
                "documents",
                "{{document_id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Import Document File",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "owner_id",
                  "value": "{{user_id}}",
                  "type": "text"
                },
                {
                  "key": "title",
                  "value": "Imported Specs",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{host}}/documents/import",
              "host": [
                "{{host}}"
              ],
              "path": [
                "documents",
                "import"
              ]
            }
          },
          "response": []
        }
      ]
